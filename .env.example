# Copy this file to .env and fill in your values. The app loads .env automatically.
# WARNING: Do not commit this file to git if it contains real API keys or passwords. Use .env for secrets (add .env to .gitignore).
# Session report emails are sent when a faculty ends a session. Without SMTP_USER and SMTP_PASS, no email is sent.

# SMTP (required for sending email)
SMTP_USER="your-email@domain.com"
SMTP_PASS="your-app-password"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=true   # use for port 465

# Optional: "From" address (defaults to SMTP_USER)
# FROM_EMAIL=noreply@rajalakshmi.edu.in

# Daily Smart Attendance email to every registered faculty (CSV attachment + HTML with rec-logo + college header).
# Sends once per calendar day in the given timezone when local time matches hour:minute. Only faculties with at least one attendance row that day receive mail.
# DAILY_ATTENDANCE_EMAIL_ENABLED=true
# DAILY_ATTENDANCE_TZ=Asia/Kolkata
# DAILY_ATTENDANCE_EMAIL_HOUR=18
# DAILY_ATTENDANCE_EMAIL_MINUTE=0

# Server
PORT=3000
SESSION_SECRET=your-session-secret

# --- Hardened deployment (nginx reverse proxy, TLS termination, Docker/K8s) ---
# Trust X-Forwarded-* from one reverse proxy hop (default in code: 1).
# TRUST_PROXY=1
# Terminate TLS at nginx/Caddy; Node listens on HTTP only inside the network.
# BEHIND_REVERSE_PROXY=true
# Let express-session treat connections as HTTPS when the proxy sends X-Forwarded-Proto: https.
# SESSION_COOKIE_TRUST_PROXY=true
# Load secrets from files (Docker Compose/Swarm secrets mount under /run/secrets/...).
# Explicit env vars above take precedence over *_FILE when both are set.
# SESSION_SECRET_FILE=/run/secrets/session_secret
# SMTP_PASS_FILE=/run/secrets/smtp_pass
# GEMINI_API_KEY_FILE=/run/secrets/gemini_api_key
# CLAUDE_API_KEY_FILE=/run/secrets/claude_api_key
# See deployment/README.md and deployment/docker-compose.yml

# Links inside emails (verify email, reveal password). Must be reachable from the recipient's device — not localhost unless they use the same PC.
# Example (Tailscale / LAN HTTPS): PUBLIC_BASE_URL=https://100.114.181.81:3443
# Legacy alias: SERVER_URL. If you register while on localhost, PUBLIC_HTTPS_URL or HTTPS_BASE_URL is used when set.
# PUBLIC_BASE_URL=
# PUBLIC_HTTPS_URL=

# Attendance restriction (campus-only):
# When enabled, Smart Attendance signing-key + submit APIs are allowed only from these CIDR ranges.
# Example campus CIDRs: CAMPUS_ATTENDANCE_ALLOWED_CIDRS=172.16.0.0/12,10.10.0.0/16,192.168.10.0/24
# CAMPUS_ATTENDANCE_ENFORCED=false
# CAMPUS_ATTENDANCE_ALLOWED_CIDRS=

# Google Sign-In (OAuth Web client ID). Authorized JavaScript origins: http://localhost:3000, https://localhost:3443, etc.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Gemini API key for AI voice assistants (optional; if set, REC EduMate / REC Smart Assist / REC Insight use Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: model name (default gemini-3-flash-preview); use the model id from Google AI Studio
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: Claude AI key (Anthropic). If set, dashboards will prefer Claude; if it fails, they fall back to Gemini/local answers.
CLAUDE_API_KEY=your_claude_api_key_here
# Optional: Claude model name (default claude-3-haiku-20240307)
# CLAUDE_MODEL=claude-3-haiku-20240307
# Optional: auto-enable AI agent right after successful dashboard login (default false)
# AUTO_ENABLE_AI_AGENT_ON_SIGNIN=false

# Optional: default country code when users enter 10 digits without + on registration (mobile field)
# SMS_DEFAULT_COUNTRY_CODE=91

# Password strategy for credentials and forgot-password resets across faculty/leadership/student.
# fixed  = role-based deterministic format (faculty/leadership: StaffID+mobile, student: Rec.<dept>@+<tail>$)
# random = secure random password generated and emailed each time
# PASSWORD_FORMAT_MODE=fixed
# Optional random password length (only used when PASSWORD_FORMAT_MODE=random; min 10, max 32)
# RANDOM_PASSWORD_LENGTH=14

# MongoDB + scaling
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=dti
# Redis URL for Socket.IO multi-instance scaling (optional; app falls back to in-memory adapter when unset)
# REDIS_URL=redis://127.0.0.1:6379
# Minimum client push interval for /api/attention/public (ms). Recommended 3000-5000.
# ATTENTION_MIN_PUSH_INTERVAL_MS=3000

# WhatsApp support (wa.me) — used by GET /api/whatsapp/support, Smart Assist footer, and “Ask on WhatsApp” in profile menus
# WHATSAPP_SUPPORT_PHONE=916383596165
# WHATSAPP_PREFILL_MESSAGE=REC SmartAssist query
